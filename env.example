# Copy this to .env for local dev — NEVER commit .env to GitHub
# Add GEMINI_API_KEY as an Environment Variable in your Vercel dashboard

# Gemini 2.5 Flash (primary — get free key at aistudio.google.com)
GEMINI_API_KEY=AIza-your-key-here

# Fallbacks (optional)
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENAI_API_KEY=sk-your-key-here

# Optional: restrict access to your extension only
# IQRA_SECRET=any-random-string-you-choose
